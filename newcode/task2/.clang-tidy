# task2 嵌入式 C（裸机 / Cortex-M、freestanding）静态检查默认配置
#
# 说明：
# - misc-misra-c2012-* 依赖 LLVM/clang-tidy 是否编译了 MISRA 模块；若报 unknown check，请升级
#   clang-tidy 或从 Checks 中删除 misc-misra-c2012-* 两行。
# - WarningsAsErrors 留空：教学场景下避免 MISRA/风格类问题全部当错误退出；请在日志中查看
#   clang-analyzer 与 MISRA 的 warning。
# - HeaderFilterRegex：仅对路径匹配的头文件输出诊断（主 .c 始终检查），减轻系统头干扰。
---
Checks: >
  clang-analyzer-*,
  misc-misra-c2012-*,
  misc-unused-parameters,
  misc-c-static-assert,
  readability-identifier-naming

WarningsAsErrors: ''

# baremetal、题目 Pxxxx、用户工程目录下的头文件
HeaderFilterRegex: '.*/(baremetal|P[0-9]{4}|user_projects)(/|\\\\).*'

FormatStyle: none

CheckOptions:
  - key: readability-identifier-naming.Function
    value: snake_case
  - key: readability-identifier-naming.Variable
    value: snake_case
  - key: readability-identifier-naming.GlobalVariable
    value: snake_case
  - key: readability-identifier-naming.Constant
    value: UPPER_CASE
  - key: readability-identifier-naming.MacroDefinition
    value: UPPER_CASE
  - key: readability-identifier-naming.Typedef
    value: CamelCase
  - key: readability-identifier-naming.EnumConstant
    value: UPPER_CASE
